rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Authentication
    // The app uses Firebase Anonymous Authentication. Any signed-in anonymous
    // Firebase user has request.auth.uid and is treated as an authenticated user.
    function isSignedIn() {
      return request.auth != null && request.auth.uid is string;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isNonEmptyString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function hasOnlyAllowedFields(allowedFields) {
      return request.resource.data.keys().hasOnly(allowedFields);
    }

    function hasRequiredFields(requiredFields) {
      return request.resource.data.keys().hasAll(requiredFields);
    }

    // User profiles
    // Private profile documents are owner-only. Public leaderboard fields are
    // duplicated onto fastingSessions so leaderboard reads do not need users/*.
    function userProfileFieldsAreValid(userId) {
      return hasOnlyAllowedFields([
          'id',
          'displayName',
          'avatarColor',
          'countryFlag',
          'premiumUnlocked',
          'createdAt',
          'updatedAt'
        ])
        && hasRequiredFields([
          'id',
          'displayName',
          'avatarColor',
          'countryFlag',
          'premiumUnlocked',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == userId
        && request.resource.data.id == request.auth.uid
        && isNonEmptyString(request.resource.data.displayName, 40)
        && isNonEmptyString(request.resource.data.avatarColor, 16)
        && isNonEmptyString(request.resource.data.countryFlag, 16)
        && request.resource.data.premiumUnlocked == true;
    }

    function userProfileCreateIsValid(userId) {
      return userProfileFieldsAreValid(userId)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function userProfileUpdateIsValid(userId) {
      return userProfileFieldsAreValid(userId)
        && resource.data.id == request.auth.uid
        && request.resource.data.id == resource.data.id
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'avatarColor',
          'countryFlag',
          'premiumUnlocked',
          'updatedAt'
        ]);
    }

    match /users/{userId} {
      allow create: if isOwner(userId) && userProfileCreateIsValid(userId);
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && userProfileUpdateIsValid(userId);
      allow delete: if false;
    }

    // Fasting sessions
    // Authenticated users can read sessions for leaderboards, but can only
    // create or update sessions that belong to their own auth UID.
    function optionalSessionFieldsAreValid() {
      return (!('contestId' in request.resource.data) || request.resource.data.contestId is string)
        && (!('contestCode' in request.resource.data) || request.resource.data.contestCode is string)
        && (!('endTime' in request.resource.data) || request.resource.data.endTime is timestamp)
        && (!('rank' in request.resource.data) || request.resource.data.rank is int);
    }

    function sessionBaseFieldsAreValid(sessionId) {
      return hasOnlyAllowedFields([
          'id',
          'userId',
          'displayName',
          'avatarColor',
          'countryFlag',
          'startTime',
          'endTime',
          'elapsedSeconds',
          'status',
          'contestId',
          'contestCode',
          'contestType',
          'rank',
          'createdAt',
          'updatedAt'
        ])
        && hasRequiredFields([
          'id',
          'userId',
          'displayName',
          'avatarColor',
          'countryFlag',
          'startTime',
          'elapsedSeconds',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == sessionId
        && request.resource.data.userId == request.auth.uid
        && isNonEmptyString(request.resource.data.displayName, 40)
        && isNonEmptyString(request.resource.data.avatarColor, 16)
        && isNonEmptyString(request.resource.data.countryFlag, 16)
        && request.resource.data.startTime is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.elapsedSeconds is int
        && request.resource.data.elapsedSeconds >= 0
        && request.resource.data.elapsedSeconds <= 259200
        && request.resource.data.status in ['active', 'stopped', 'completed']
        && optionalSessionFieldsAreValid();
    }

    function sessionCreateIsValid(sessionId) {
      return sessionBaseFieldsAreValid(sessionId)
        && request.resource.data.status == 'active'
        && request.resource.data.elapsedSeconds == 0
        && request.resource.data.startTime is timestamp
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function sessionUpdateIsValid(sessionId) {
      return resource.data.userId == request.auth.uid
        && sessionBaseFieldsAreValid(sessionId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.startTime == resource.data.startTime
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'elapsedSeconds',
          'endTime',
          'rank',
          'updatedAt'
        ])
        && sessionStatusTransitionIsValid();
    }

    function sessionStatusTransitionIsValid() {
      return resource.data.status == 'active'
        && (
          stoppedSessionUpdateIsValid()
          || completedSessionUpdateIsValid()
        );
    }

    function stoppedSessionUpdateIsValid() {
      return request.resource.data.status == 'stopped'
        && request.resource.data.endTime is timestamp
        && request.resource.data.endTime >= resource.data.startTime
        && request.resource.data.endTime <= request.time
        && request.resource.data.elapsedSeconds >= 0
        && request.resource.data.elapsedSeconds < 259200;
    }

    function completedSessionUpdateIsValid() {
      return request.resource.data.status == 'completed'
        && request.resource.data.endTime is timestamp
        && request.time >= resource.data.startTime + duration.value(72, 'h')
        && request.resource.data.endTime >= resource.data.startTime + duration.value(72, 'h')
        && request.resource.data.endTime <= request.time
        && request.resource.data.elapsedSeconds == 259200;
    }

    match /fastingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && sessionCreateIsValid(sessionId);
      allow update: if isSignedIn() && sessionUpdateIsValid(sessionId);
      allow delete: if false;
    }

    // Private contests
    // Authenticated users can read contests so invite-code lookup works.
    // Creation is limited to contests owned by the creator. Updates are limited
    // to safe joins: users may add only themselves to participantIds.
    function contestFieldsAreValid(contestId) {
      return hasOnlyAllowedFields([
          'id',
          'title',
          'contestCode',
          'creatorUserId',
          'isPrivate',
          'participantIds',
          'sessionIds',
          'createdAt',
          'updatedAt'
        ])
        && hasRequiredFields([
          'id',
          'title',
          'contestCode',
          'creatorUserId',
          'isPrivate',
          'participantIds',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.id == contestId
        && isNonEmptyString(request.resource.data.title, 80)
        && request.resource.data.contestCode.matches('^FAST-[0-9A-Z]{4,8}$')
        && request.resource.data.creatorUserId is string
        && request.resource.data.isPrivate == true
        && request.resource.data.participantIds is list
        && request.resource.data.participantIds.size() >= 1
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (!('sessionIds' in request.resource.data) || request.resource.data.sessionIds is list);
    }

    function contestCreateIsValid(contestId) {
      return contestFieldsAreValid(contestId)
        && request.resource.data.creatorUserId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function contestImmutableFieldsAreUnchanged() {
      return request.resource.data.id == resource.data.id
        && request.resource.data.creatorUserId == resource.data.creatorUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.contestCode == resource.data.contestCode
        && request.resource.data.isPrivate == resource.data.isPrivate;
    }

    function joinsOnlySelf() {
      return request.resource.data.participantIds.hasAll(resource.data.participantIds)
        && request.auth.uid in request.resource.data.participantIds
        && (
          request.auth.uid in resource.data.participantIds
          || request.resource.data.participantIds.size() == resource.data.participantIds.size() + 1
        )
        && request.resource.data.participantIds.size() <= resource.data.participantIds.size() + 1;
    }

    function leavesOnlySelf() {
      return resource.data.creatorUserId != request.auth.uid
        && request.auth.uid in resource.data.participantIds
        && !(request.auth.uid in request.resource.data.participantIds)
        && resource.data.participantIds.hasAll(request.resource.data.participantIds)
        && request.resource.data.participantIds.size() == resource.data.participantIds.size() - 1;
    }

    function contestJoinUpdateIsValid(contestId) {
      return contestFieldsAreValid(contestId)
        && contestImmutableFieldsAreUnchanged()
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participantIds',
          'updatedAt'
        ])
        && joinsOnlySelf();
    }

    function contestLeaveUpdateIsValid(contestId) {
      return contestFieldsAreValid(contestId)
        && contestImmutableFieldsAreUnchanged()
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'participantIds',
          'updatedAt'
        ])
        && leavesOnlySelf();
    }

    match /contests/{contestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && contestCreateIsValid(contestId);
      allow update: if isSignedIn() && (
        contestJoinUpdateIsValid(contestId)
        || contestLeaveUpdateIsValid(contestId)
      );
      allow delete: if isSignedIn() && resource.data.creatorUserId == request.auth.uid;
    }

    // Badges
    // Badges are private to the owner. The app can create or idempotently update
    // a badge only when badge.userId matches request.auth.uid.
    function badgeFieldsAreValid(badgeId) {
      return hasOnlyAllowedFields([
          'id',
          'userId',
          'badgeType',
          'unlockedAt'
        ])
        && hasRequiredFields([
          'id',
          'userId',
          'badgeType',
          'unlockedAt'
        ])
        && request.resource.data.id == badgeId
        && request.resource.data.userId == request.auth.uid
        && isNonEmptyString(request.resource.data.badgeType, 60)
        && request.resource.data.unlockedAt == request.time;
    }

    function badgeUpdateIsValid(badgeId) {
      return resource.data.userId == request.auth.uid
        && badgeFieldsAreValid(badgeId)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.badgeType == resource.data.badgeType
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'unlockedAt'
        ]);
    }

    match /badges/{badgeId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && badgeFieldsAreValid(badgeId);
      allow update: if isSignedIn() && badgeUpdateIsValid(badgeId);
      allow delete: if false;
    }
  }
}
